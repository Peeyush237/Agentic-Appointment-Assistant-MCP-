# Core
APP_NAME=Appointment MCP Tracker
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/appointment_mcp

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# MCP routing (points to MCP server endpoint, can be same app)
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Google Calendar (optional: if missing, app runs in mock mode)
GOOGLE_CALENDAR_ID=primary
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_TIMEZONE=Asia/Kolkata

# Email service (SendGrid)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=no-reply@clinic.local
EMAIL_API_KEY=

# Doctor notification platform (WhatsApp via Twilio; mock if missing)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DOCTOR_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Seeded doctor portal login (for first run)
DEFAULT_DOCTOR_LOGIN_EMAIL=doctor@clinic.local
DEFAULT_DOCTOR_LOGIN_PASSWORD=doctor123
